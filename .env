# データベース接続設定
DB_HOST=localhost
DB_PORT=3306
DB_NAME=inventory_db_db
DB_USER=root
DB_PASSWORD=your_database_password

# メール送信設定

# SMTPサーバー設定
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# SMTP認証情報
# Gmailの場合: Googleアカウントでアプリパスワードを生成してください
# https://support.google.com/accounts/answer/185833
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=daisoseisanka1470-3

# 送信元メールアドレスと名前
FROM_EMAIL=your-email@gmail.com
FROM_NAME=ダイソウ工業株式会社

# Flask設定
SECRET_KEY=your-secret-key-change-this-in-production

# 使い方:
# 1. このファイルを .env にコピーまたはリネームしてください
# 2. 上記の値を実際の値に置き換えてください
# 3. .envファイルはGitにコミットしないでください（.gitignoreに追加済み）
